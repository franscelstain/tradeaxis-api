APP_NAME="TradeAxis Market Data API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:3001
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tradeaxis
DB_USERNAME=root
DB_PASSWORD=
DB_SOCKET=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=
DB_STRICT_MODE=true

MARKET_DATA_PLATFORM_TIMEZONE=Asia/Jakarta
MARKET_DATA_SEAL_REQUIRED_FOR_CONSUMERS=true
MARKET_DATA_PLATFORM_EOD_CUTOFF_TIME=17:15:00
MARKET_DATA_CUT_OFF_GRACE_MINUTES=15
MARKET_DATA_COVERAGE_MIN=0.98
MARKET_DATA_PRICE_BASIS_DEFAULT=close
MARKET_DATA_LOT_SIZE=100
MARKET_DATA_DAILY_ENABLED=false
MARKET_DATA_DEFAULT_SOURCE_MODE=api
MARKET_DATA_INDICATOR_SET_VERSION=v1
MARKET_DATA_DV_WINDOW_DAYS=20
MARKET_DATA_ATR_WINDOW_DAYS=14
MARKET_DATA_VOL_RATIO_LOOKBACK_DAYS=20
MARKET_DATA_ROC_LOOKBACK_DAYS=20
MARKET_DATA_HH_WINDOW_DAYS=20
MARKET_DATA_HASH_ALGORITHM=SHA-256
MARKET_DATA_HASH_DELIMITER=|
MARKET_DATA_HASH_LINE_SEPARATOR="\n"
MARKET_DATA_HASH_NULL_TOKEN=
MARKET_DATA_API_RETRY_MAX=3
MARKET_DATA_API_BACKOFF_MS=500
MARKET_DATA_API_THROTTLE_QPS=5
MARKET_DATA_CIRCUIT_BREAKER_ERROR_RATE=0.5
MARKET_DATA_SESSION_SNAPSHOT_RETENTION_DAYS=30
MARKET_DATA_SESSION_SNAPSHOT_SCOPE_DEFAULT=eligibility_set
MARKET_DATA_SESSION_SNAPSHOT_SLOT_TOLERANCE_MINUTES=3

MARKET_DATA_SOURCE_LOCAL_DIRECTORY=storage/app/market_data/eod_bars
MARKET_DATA_SOURCE_FILE_TEMPLATE_JSON={date}.json
MARKET_DATA_SOURCE_FILE_TEMPLATE_CSV={date}.csv
MARKET_DATA_SOURCE_DEFAULT_NAME=YAHOO_FINANCE
MARKET_DATA_SOURCE_API_PROVIDER=yahoo_finance
MARKET_DATA_SOURCE_API_ENDPOINT_TEMPLATE=https://query1.finance.yahoo.com/v8/finance/chart/{symbol}{symbol_suffix}?interval=1d&range=10d&includePrePost=false&events=div%2Csplits&corsDomain=finance.yahoo.com
MARKET_DATA_SOURCE_API_RESPONSE_FORMAT=json
MARKET_DATA_SOURCE_API_ROWS_PATH=
MARKET_DATA_SOURCE_API_TIMEOUT_SECONDS=15
MARKET_DATA_SOURCE_API_AUTH_HEADER_NAME=
MARKET_DATA_SOURCE_API_AUTH_TOKEN=
MARKET_DATA_SOURCE_API_NAME=YAHOO_FINANCE
MARKET_DATA_SOURCE_YAHOO_SYMBOL_SUFFIX=.JK
MARKET_DATA_SOURCE_YAHOO_RANGE=10d
MARKET_DATA_SOURCE_YAHOO_INTERVAL=1d
MARKET_DATA_SOURCE_API_FIELD_TICKER_CODE=ticker_code
MARKET_DATA_SOURCE_API_FIELD_TRADE_DATE=trade_date
MARKET_DATA_SOURCE_API_FIELD_OPEN=open
MARKET_DATA_SOURCE_API_FIELD_HIGH=high
MARKET_DATA_SOURCE_API_FIELD_LOW=low
MARKET_DATA_SOURCE_API_FIELD_CLOSE=close
MARKET_DATA_SOURCE_API_FIELD_VOLUME=volume
MARKET_DATA_SOURCE_API_FIELD_ADJ_CLOSE=adj_close
MARKET_DATA_SOURCE_API_FIELD_SOURCE_ROW_REF=source_row_ref
MARKET_DATA_SOURCE_API_FIELD_CAPTURED_AT=captured_at
MARKET_DATA_TICKERS_TABLE=tickers
MARKET_DATA_TICKERS_ID_COLUMN=ticker_id
MARKET_DATA_TICKERS_CODE_COLUMN=ticker_code
MARKET_DATA_TICKERS_ACTIVE_COLUMN=is_active
MARKET_DATA_TICKERS_ACTIVE_YES_VALUE=Yes
MARKET_DATA_TICKERS_LISTED_DATE_COLUMN=listed_date
MARKET_DATA_TICKERS_DELISTED_DATE_COLUMN=delisted_date

MARKET_DATA_EVIDENCE_OUTPUT_DIRECTORY=storage/app/market_data/evidence
MARKET_DATA_INVALID_BARS_EXPORT_SAMPLE_LIMIT=1000
